{
  "id": "task-to-implement",
  "name": "Task -> Implement",
  "description": "Resolve a task and execute implementation through the canonical task pipeline.",
  "acceptanceCriteria": [
    "Produces a persisted workflow run record",
    "Returns implementation outcome summary"
  ],
  "version": 1,
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "required": [
      "taskId"
    ],
    "properties": {
      "taskId": {
        "type": "string"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "taskId": {
        "type": "string"
      },
      "completed": {
        "type": "boolean"
      },
      "message": {
        "type": "string"
      }
    }
  },
  "steps": [
    {
      "id": "resolve-task",
      "type": "extract",
      "name": "Resolve task id from input",
      "config": {
        "from": "input",
        "fields": [
          "taskId"
        ]
      }
    },
    {
      "id": "implement",
      "type": "action",
      "name": "Run implement pipeline",
      "config": {
        "action": "implement",
        "bodyTemplate": {
          "taskId": "{{steps.resolve-task.taskId}}"
        }
      }
    },
    {
      "id": "response",
      "type": "response",
      "name": "Return implementation summary",
      "config": {
        "fields": [
          "steps.implement.taskId",
          "steps.implement.completed",
          "steps.implement.message"
        ]
      }
    }
  ],
  "createdAt": 1776696758772,
  "updatedAt": 1776696758772
}