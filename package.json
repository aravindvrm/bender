{
  "name": "bender",
  "version": "0.1.0",
  "description": "AI-powered software factory — turns messy product ideas into maintainable codebases",
  "type": "module",
  "bin": {
    "bender": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/llm/prompts dist/llm/prompts && npm run build:web",
    "build:cli": "tsc && cp -r src/llm/prompts dist/llm/prompts",
    "build:web": "vite build --config src/web/vite.config.ts",
    "dev": "tsc --watch",
    "dev:web": "vite --config src/web/vite.config.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "code-generation",
    "scaffolding",
    "architecture",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.62",
    "@ai-sdk/openai": "^3.0.52",
    "ai": "^6.0.158",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ora": "^9.3.0",
    "simple-git": "^3.35.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
